<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Arcana Analytics</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
<script src="https://unpkg.com/lucide@latest"></script>
<style>
  :root {
    --bg-primary: #0a0a0a;
    --bg-secondary: #111111;
    --bg-card: #141414;
    --bg-card-hover: #1a1a1a;
    --text-primary: #ededed;
    --text-secondary: #888888;
    --text-tertiary: #555555;
    --accent: #0070f3;
    --accent-dim: #0070f322;
    --success: #0cce6b;
    --success-dim: #0cce6b18;
    --warning: #f5a623;
    --warning-dim: #f5a62318;
    --danger: #ee0000;
    --danger-dim: #ee000018;
    --border: #222222;
    --border-light: #2a2a2a;
  }
  .light {
    --bg-primary: #fafafa;
    --bg-secondary: #f5f5f5;
    --bg-card: #ffffff;
    --bg-card-hover: #fafafa;
    --text-primary: #171717;
    --text-secondary: #666666;
    --text-tertiary: #999999;
    --accent: #0070f3;
    --accent-dim: #0070f30a;
    --success: #0cce6b;
    --success-dim: #0cce6b0a;
    --warning: #f5a623;
    --warning-dim: #f5a6230a;
    --danger: #ee0000;
    --danger-dim: #ee00000a;
    --border: #eaeaea;
    --border-light: #f0f0f0;
  }
  * { box-sizing: border-box; }
  body {
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    margin: 0;
    -webkit-font-smoothing: antialiased;
  }
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .text-muted { color: var(--text-secondary); }
  .text-dim { color: var(--text-tertiary); }

  /* Tabs */
  .tab-bar { border-bottom: 1px solid var(--border); }
  .tab-btn {
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    border: none;
    background: none;
    cursor: pointer;
    position: relative;
    transition: color 0.15s;
  }
  .tab-btn:hover { color: var(--text-primary); }
  .tab-btn.active {
    color: var(--text-primary);
  }
  .tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--text-primary);
    border-radius: 1px;
  }

  /* KPI */
  .kpi-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1px; background: var(--border); border-radius: 8px; overflow: hidden; }
  .kpi-cell { background: var(--bg-card); padding: 20px 16px; }
  .kpi-label { font-size: 12px; color: var(--text-secondary); margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
  .kpi-label i { width: 14px; height: 14px; opacity: 0.5; }
  .kpi-value { font-size: 24px; font-weight: 600; letter-spacing: -0.5px; line-height: 1; }
  .kpi-sub { font-size: 11px; color: var(--text-tertiary); margin-top: 6px; }

  /* Tables */
  table { width: 100%; border-collapse: collapse; }
  th {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    text-align: left;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
  }
  th:hover { color: var(--text-primary); }
  td {
    font-size: 13px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  tr:last-child td { border-bottom: none; }
  tbody tr { transition: background 0.1s; }
  tbody tr:hover { background: var(--bg-card-hover); }
  .sort-indicator { opacity: 0.3; margin-left: 4px; }
  th.sorted .sort-indicator { opacity: 1; }

  /* Charts */
  .chart-container { width: 100%; position: relative; }

  /* Badge */
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 500;
  }
  .badge-green { background: var(--success-dim); color: var(--success); }
  .badge-yellow { background: var(--warning-dim); color: var(--warning); }
  .badge-red { background: var(--danger-dim); color: var(--danger); }
  .badge-blue { background: var(--accent-dim); color: var(--accent); }

  /* Hotspot card */
  .hotspot { background: var(--bg-secondary); border-radius: 6px; padding: 12px 16px; margin-bottom: 8px; }

  @media (max-width: 768px) {
    .kpi-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<!-- ANALYTICS_DATA_START -->
<!-- ANALYTICS_DATA_END -->
</head>
<body>
<div x-data="dashboard()" x-init="init()" class="min-h-screen">

  <!-- Header -->
  <header style="border-bottom: 1px solid var(--border); padding: 16px 24px; display: flex; align-items: center; justify-content: space-between;">
    <div>
      <div style="display: flex; align-items: center; gap: 10px;">
        <i data-lucide="bar-chart-3" style="width: 20px; height: 20px; color: var(--text-primary);"></i>
        <h1 style="font-size: 15px; font-weight: 600; margin: 0;">Arcana Analytics</h1>
      </div>
      <p style="font-size: 12px; color: var(--text-secondary); margin: 4px 0 0 30px;" x-text="data ? `${data.range} · ${data.total_projects_scanned} projects · ${data.generated?.slice(0,10)}` : ''"></p>
    </div>
    <div style="display: flex; align-items: center; gap: 8px;">
      <button @click="toggleTheme()" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 6px; padding: 6px 12px; font-size: 12px; color: var(--text-secondary); cursor: pointer; display: flex; align-items: center; gap: 4px;">
        <i :data-lucide="darkMode ? 'sun' : 'moon'" style="width: 13px; height: 13px;"></i>
        <span x-text="darkMode ? 'Light' : 'Dark'"></span>
      </button>
      <button @click="refresh()" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 6px; padding: 6px 12px; font-size: 12px; color: var(--text-secondary); cursor: pointer; display: flex; align-items: center; gap: 4px;">
        <i data-lucide="refresh-cw" style="width: 13px; height: 13px;"></i>
        Refresh
      </button>
    </div>
  </header>

  <!-- Loading / Error -->
  <div x-show="!data && !error" style="display: flex; align-items: center; justify-content: center; height: 60vh;">
    <p class="text-muted" style="font-size: 13px;">Loading...</p>
  </div>
  <div x-show="error" style="display: flex; align-items: center; justify-content: center; height: 60vh; flex-direction: column; gap: 12px;">
    <i data-lucide="alert-circle" style="width: 32px; height: 32px; color: var(--danger);"></i>
    <p style="color: var(--danger); font-size: 14px;" x-text="error"></p>
    <code style="font-size: 12px; color: var(--text-secondary); background: var(--bg-card); padding: 8px 16px; border-radius: 6px;">python3 00-Dashboard/analytics_engine.py</code>
  </div>

  <!-- Tabs -->
  <nav x-show="data" class="tab-bar" style="padding: 0 24px; display: flex; gap: 0;">
    <template x-for="t in tabs" :key="t.id">
      <button @click="switchTab(t.id)"
        :class="tab === t.id ? 'tab-btn active' : 'tab-btn'"
        style="display: flex; align-items: center; gap: 6px;">
        <i :data-lucide="t.icon" style="width: 14px; height: 14px;"></i>
        <span x-text="t.label"></span>
      </button>
    </template>
  </nav>

  <!-- Content -->
  <main x-show="data" style="padding: 24px; max-width: 1200px; margin: 0 auto;">

    <!-- Tab 1: Overview -->
    <div x-show="tab === 'overview'">
      <!-- KPI Grid -->
      <div class="kpi-grid" style="margin-bottom: 24px;">
        <div class="kpi-cell">
          <div class="kpi-label"><i data-lucide="dollar-sign"></i> Total Cost</div>
          <div class="kpi-value" x-text="'$' + fmt(data?.summary?.total_cost_usd)"></div>
          <div class="kpi-sub" x-text="fmt(data?.summary?.total_tokens / 1e9, 1) + 'B tokens'"></div>
        </div>
        <div class="kpi-cell">
          <div class="kpi-label"><i data-lucide="activity"></i> Sessions</div>
          <div class="kpi-value" x-text="data?.summary?.total_sessions?.toLocaleString()"></div>
          <div class="kpi-sub" x-text="'$' + fmt(data?.summary?.total_sessions > 0 ? data?.summary?.total_cost_usd / data?.summary?.total_sessions : 0) + '/session avg'"></div>
        </div>
        <div class="kpi-cell">
          <div class="kpi-label"><i data-lucide="coins"></i> Tokens</div>
          <div class="kpi-value" x-text="fmt(data?.summary?.total_tokens / 1e9, 1) + 'B'"></div>
          <div class="kpi-sub" x-text="fmt(data?.summary?.total_tokens / Math.max(data?.summary?.total_sessions, 1) / 1e6, 1) + 'M/session'"></div>
        </div>
        <div class="kpi-cell">
          <div class="kpi-label"><i data-lucide="receipt"></i> Avg Cost/Session</div>
          <div class="kpi-value" x-text="'$' + fmt(data?.summary?.total_sessions > 0 ? data?.summary?.total_cost_usd / data?.summary?.total_sessions : 0)"></div>
        </div>
        <div class="kpi-cell">
          <div class="kpi-label"><i data-lucide="hand"></i> HIR</div>
          <div class="kpi-value" :style="`color: ${hirColor(data?.summary?.avg_hir)}`" x-text="pct(data?.summary?.avg_hir)"></div>
          <div class="kpi-sub">human intervention rate</div>
        </div>
        <div class="kpi-cell">
          <div class="kpi-label"><i data-lucide="frown"></i> Frustration</div>
          <div class="kpi-value" :style="`color: ${frustColor(data?.summary?.avg_frustration)}`" x-text="fmt(data?.summary?.avg_frustration, 1)"></div>
          <div class="kpi-sub">avg score (0-10)</div>
        </div>
        <div class="kpi-cell">
          <div class="kpi-label"><i data-lucide="target"></i> Tool Precision</div>
          <div class="kpi-value" :style="`color: ${data?.summary?.avg_tool_precision > 0.9 ? 'var(--success)' : 'var(--warning)'}`" x-text="pct(data?.summary?.avg_tool_precision)"></div>
        </div>
        <div class="kpi-cell">
          <div class="kpi-label"><i data-lucide="terminal"></i> Commands</div>
          <div class="kpi-value" x-text="data?.summary?.total_commands_used?.toLocaleString()"></div>
          <div class="kpi-sub" x-text="Object.keys(data?.command_frequency || {}).length + ' unique'"></div>
        </div>
        <div class="kpi-cell">
          <div class="kpi-label"><i data-lucide="git-branch"></i> Subagent Ratio</div>
          <div class="kpi-value" x-text="pct(data?.summary?.total_subagent_sessions / Math.max(data?.summary?.total_sessions, 1))"></div>
          <div class="kpi-sub" x-text="data?.summary?.total_subagent_sessions + ' sessions with subagents'"></div>
        </div>
        <div class="kpi-cell">
          <div class="kpi-label"><i data-lucide="crown"></i> Top Domain</div>
          <div class="kpi-value" style="font-size: 18px;" x-text="(data?.domains?.[0]?.name || '-')"></div>
          <div class="kpi-sub" x-text="data?.domains?.[0] ? '$' + fmt(data.domains[0].cost) : ''"></div>
        </div>
      </div>

      <!-- Heatmap -->
      <div class="card" style="padding: 20px; margin-bottom: 24px;">
        <div style="font-size: 13px; font-weight: 500; margin-bottom: 16px; display: flex; align-items: center; gap: 6px;">
          <i data-lucide="grid-3x3" style="width: 14px; height: 14px; color: var(--text-secondary);"></i>
          <span>Token Heatmap</span>
          <span class="text-muted" style="font-size: 11px; margin-left: 4px;">days x hours</span>
        </div>
        <div x-ref="heatmapChart" class="chart-container" style="height: 280px;"></div>
      </div>

      <!-- Daily Trend -->
      <div class="card" style="padding: 20px;">
        <div style="font-size: 13px; font-weight: 500; margin-bottom: 16px; display: flex; align-items: center; gap: 6px;">
          <i data-lucide="trending-up" style="width: 14px; height: 14px; color: var(--text-secondary);"></i>
          <span>Daily Trend</span>
        </div>
        <div x-ref="dailyChart" class="chart-container" style="height: 260px;"></div>
      </div>
    </div>

    <!-- Tab 2: Domains -->
    <div x-show="tab === 'domains'">
      <div class="card" style="padding: 20px; margin-bottom: 24px;">
        <div style="font-size: 13px; font-weight: 500; margin-bottom: 16px; display: flex; align-items: center; gap: 6px;">
          <i data-lucide="layers" style="width: 14px; height: 14px; color: var(--text-secondary);"></i>
          <span>Cost by Domain</span>
        </div>
        <div x-ref="domainChart" class="chart-container" style="height: 240px;"></div>
      </div>
      <div class="card" style="overflow: hidden;">
        <table>
          <thead>
            <tr>
              <th>Domain</th><th>Sessions</th><th>Tokens</th><th>Cost</th><th>HIR</th><th>Subagent Ratio</th>
            </tr>
          </thead>
          <tbody>
            <template x-for="d in data?.domains || []" :key="d.name">
              <tr style="cursor: pointer;" @click="filterDomain = filterDomain === d.name ? null : d.name"
                  :style="filterDomain === d.name ? 'background: var(--bg-card-hover)' : ''">
                <td style="font-weight: 500;" x-text="d.name"></td>
                <td x-text="d.sessions"></td>
                <td x-text="fmt(d.tokens / 1e6, 1) + 'M'"></td>
                <td x-text="'$' + fmt(d.cost)"></td>
                <td><span :class="hirBadge(d.hir)" class="badge" x-text="pct(d.hir)"></span></td>
                <td x-text="pct(d.subagent_ratio)"></td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Tab 3: Sessions -->
    <div x-show="tab === 'sessions'">
      <div class="card" style="overflow: hidden; margin-bottom: 24px;">
        <table>
          <thead>
            <tr>
              <th @click="toggleSort('date')" :class="sortCol==='date' ? 'sorted' : ''">Date <span class="sort-indicator" x-text="sortCol==='date' ? (sortDir==='asc' ? '↑' : '↓') : '↕'"></span></th>
              <th @click="toggleSort('project')" :class="sortCol==='project' ? 'sorted' : ''">Project <span class="sort-indicator" x-text="sortCol==='project' ? (sortDir==='asc' ? '↑' : '↓') : '↕'"></span></th>
              <th @click="toggleSort('cost')" :class="sortCol==='cost' ? 'sorted' : ''">Cost <span class="sort-indicator" x-text="sortCol==='cost' ? (sortDir==='asc' ? '↑' : '↓') : '↕'"></span></th>
              <th @click="toggleSort('tokens')" :class="sortCol==='tokens' ? 'sorted' : ''">Tokens <span class="sort-indicator" x-text="sortCol==='tokens' ? (sortDir==='asc' ? '↑' : '↓') : '↕'"></span></th>
              <th @click="toggleSort('hir')" :class="sortCol==='hir' ? 'sorted' : ''">HIR <span class="sort-indicator" x-text="sortCol==='hir' ? (sortDir==='asc' ? '↑' : '↓') : '↕'"></span></th>
              <th @click="toggleSort('frustration')" :class="sortCol==='frustration' ? 'sorted' : ''">Frust. <span class="sort-indicator" x-text="sortCol==='frustration' ? (sortDir==='asc' ? '↑' : '↓') : '↕'"></span></th>
              <th style="cursor: default;">First Prompt</th>
            </tr>
          </thead>
          <tbody>
            <template x-for="s in sortedSessions()" :key="s.id">
              <tr>
                <td class="text-muted" x-text="s.date"></td>
                <td style="font-weight: 500;" x-text="s.project"></td>
                <td x-text="'$' + fmt(s.cost)"></td>
                <td x-text="fmt(s.tokens / 1e6, 1) + 'M'"></td>
                <td><span :class="hirBadge(s.hir)" class="badge" x-text="pct(s.hir)"></span></td>
                <td><span :class="frustBadge(s.frustration)" class="badge" x-text="s.frustration"></span></td>
                <td style="max-width: 280px; overflow: hidden; text-overflow: ellipsis; color: var(--text-secondary); font-size: 12px;" x-text="s.first_prompt"></td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>

      <!-- Frustration Hotspots -->
      <template x-if="(data?.frustration_hotspots || []).length > 0">
        <div>
          <div style="font-size: 13px; font-weight: 500; margin-bottom: 12px; display: flex; align-items: center; gap: 6px;">
            <i data-lucide="flame" style="width: 14px; height: 14px; color: var(--danger);"></i>
            <span>Frustration Hotspots</span>
            <span class="badge badge-red" x-text="'score > 5'"></span>
          </div>
          <template x-for="h in data.frustration_hotspots" :key="h.session_id">
            <div class="hotspot">
              <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
                <span style="font-size: 13px; font-weight: 500;" x-text="h.project"></span>
                <span class="text-dim" style="font-size: 11px;" x-text="h.date"></span>
                <span class="badge badge-red" x-text="h.score + '/10'"></span>
              </div>
              <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                <template x-for="t in h.triggers" :key="t">
                  <span style="font-size: 11px; color: var(--text-secondary); background: var(--bg-card); padding: 2px 8px; border-radius: 4px;" x-text="t"></span>
                </template>
              </div>
            </div>
          </template>
        </div>
      </template>
    </div>

    <!-- Tab 4: Tools & Commands -->
    <div x-show="tab === 'tools'">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;">
        <div class="card" style="padding: 20px;">
          <div style="font-size: 13px; font-weight: 500; margin-bottom: 16px; display: flex; align-items: center; gap: 6px;">
            <i data-lucide="terminal" style="width: 14px; height: 14px; color: var(--text-secondary);"></i>
            <span>Command Frequency</span>
          </div>
          <div x-ref="cmdChart" class="chart-container" style="height: 320px;"></div>
        </div>
        <div class="card" style="padding: 20px;">
          <div style="font-size: 13px; font-weight: 500; margin-bottom: 16px; display: flex; align-items: center; gap: 6px;">
            <i data-lucide="target" style="width: 14px; height: 14px; color: var(--text-secondary);"></i>
            <span>Tool Precision</span>
          </div>
          <div x-ref="toolChart" class="chart-container" style="height: 320px;"></div>
        </div>
      </div>
      <div class="card" style="padding: 20px;">
        <div style="font-size: 13px; font-weight: 500; margin-bottom: 16px; display: flex; align-items: center; gap: 6px;">
          <i data-lucide="git-branch" style="width: 14px; height: 14px; color: var(--text-secondary);"></i>
          <span>Sessions: HIR vs Cost</span>
        </div>
        <div x-ref="scatterChart" class="chart-container" style="height: 280px;"></div>
      </div>
    </div>

    <!-- Tab 5: Context -->
    <div x-show="tab === 'context'">
      <div class="card" style="padding: 20px;">
        <div style="font-size: 13px; font-weight: 500; margin-bottom: 16px; display: flex; align-items: center; gap: 6px;">
          <i data-lucide="brain" style="width: 14px; height: 14px; color: var(--text-secondary);"></i>
          <span>Context Fill Rate</span>
          <span class="text-muted" style="font-size: 11px; margin-left: 4px;">top 10 longest sessions</span>
        </div>
        <div x-ref="contextChart" class="chart-container" style="height: 380px;"></div>
      </div>
    </div>
  </main>
</div>

<script>
function dashboard() {
  return {
    data: null,
    error: null,
    tab: 'overview',
    darkMode: true,
    filterDomain: null,
    sortCol: 'cost',
    sortDir: 'desc',
    charts: {},
    tabs: [
      { id: 'overview', label: 'Overview', icon: 'layout-dashboard' },
      { id: 'domains', label: 'Domains', icon: 'layers' },
      { id: 'sessions', label: 'Sessions', icon: 'list' },
      { id: 'tools', label: 'Tools & Commands', icon: 'wrench' },
      { id: 'context', label: 'Context', icon: 'brain' },
    ],

    async init() {
      this.darkMode = localStorage.getItem('analytics-theme') !== 'light';
      this.applyTheme();
      await this.loadData();
      setInterval(() => {
        if (document.visibilityState === 'visible') this.loadData();
      }, 60000);
      this.$watch('tab', () => {
        this.$nextTick(() => { this.renderCharts(); this.refreshIcons(); });
      });
    },

    async loadData() {
      try {
        if (window.__ANALYTICS_DATA__) {
          this.data = window.__ANALYTICS_DATA__;
          this.error = null;
          this.$nextTick(() => { this.renderCharts(); this.refreshIcons(); });
          return;
        }
        const res = await fetch('data.json?t=' + Date.now());
        if (!res.ok) throw new Error('not found');
        this.data = await res.json();
        this.error = null;
        this.$nextTick(() => { this.renderCharts(); this.refreshIcons(); });
      } catch (e) {
        this.error = 'Could not load data.json';
      }
    },

    async refresh() { await this.loadData(); },

    switchTab(id) {
      this.tab = id;
    },

    refreshIcons() {
      if (window.lucide) lucide.createIcons();
    },

    toggleTheme() {
      this.darkMode = !this.darkMode;
      localStorage.setItem('analytics-theme', this.darkMode ? 'dark' : 'light');
      this.applyTheme();
      this.$nextTick(() => { this.renderCharts(); this.refreshIcons(); });
    },

    applyTheme() {
      document.documentElement.classList.toggle('light', !this.darkMode);
    },

    // Helpers
    fmt(v, d=2) { return v != null ? Number(v).toFixed(d) : '-'; },
    pct(v) { return v != null ? (v * 100).toFixed(1) + '%' : '-'; },

    hirColor(v) {
      if (v == null) return 'var(--text-primary)';
      return v < 0.1 ? 'var(--success)' : v < 0.2 ? 'var(--warning)' : 'var(--danger)';
    },
    frustColor(v) {
      if (v == null) return 'var(--text-primary)';
      return v < 3 ? 'var(--success)' : v < 6 ? 'var(--warning)' : 'var(--danger)';
    },
    hirBadge(v) { return v < 0.1 ? 'badge-green' : v < 0.2 ? 'badge-yellow' : 'badge-red'; },
    frustBadge(v) { return v < 3 ? 'badge-green' : v < 6 ? 'badge-yellow' : 'badge-red'; },

    sortedSessions() {
      let sessions = [...(this.data?.costly_sessions || [])];
      if (this.filterDomain) sessions = sessions.filter(s => s.domain === this.filterDomain);
      const col = this.sortCol, dir = this.sortDir === 'asc' ? 1 : -1;
      sessions.sort((a, b) => {
        const va = a[col] ?? '', vb = b[col] ?? '';
        return (typeof va === 'number' ? (va - vb) : String(va).localeCompare(String(vb))) * dir;
      });
      return sessions;
    },

    toggleSort(col) {
      if (this.sortCol === col) { this.sortDir = this.sortDir === 'asc' ? 'desc' : 'asc'; }
      else { this.sortCol = col; this.sortDir = 'desc'; }
    },

    echartsTheme() {
      const isDark = this.darkMode;
      return {
        bg: isDark ? '#0a0a0a' : '#fafafa',
        text: isDark ? '#888' : '#666',
        axis: isDark ? '#222' : '#eaeaea',
        tooltip: isDark ? '#1a1a1a' : '#fff',
        tooltipBorder: isDark ? '#333' : '#eaeaea',
      };
    },

    disposeChart(ref) {
      if (this.charts[ref]) { this.charts[ref].dispose(); delete this.charts[ref]; }
    },

    getChart(ref) {
      const el = this.$refs[ref];
      if (!el) return null;
      this.disposeChart(ref);
      const chart = echarts.init(el, null, { renderer: 'canvas' });
      this.charts[ref] = chart;
      return chart;
    },

    renderCharts() {
      if (!this.data) return;
      const t = this.echartsTheme();
      const accent = '#0070f3';
      const success = '#0cce6b';
      const warning = '#f5a623';
      const danger = '#ee0000';

      if (this.tab === 'overview') {
        // Heatmap
        const hm = this.getChart('heatmapChart');
        if (hm) {
          const heatmap = this.data.heatmap || {};
          const days = Object.keys(heatmap).sort();
          const hmData = [];
          let maxVal = 0;
          days.forEach((day, di) => {
            for (let h = 0; h < 24; h++) {
              const val = heatmap[day]?.[String(h).padStart(2, '0')] || 0;
              hmData.push([di, h, val]);
              if (val > maxVal) maxVal = val;
            }
          });
          hm.setOption({
            tooltip: { formatter: p => `${days[p.data[0]]} ${String(p.data[1]).padStart(2,'0')}:00<br/>${(p.data[2]/1e6).toFixed(1)}M tokens`, backgroundColor: t.tooltip, borderColor: t.tooltipBorder, textStyle: { color: this.darkMode ? '#eee' : '#333', fontSize: 12 } },
            grid: { left: 50, right: 20, top: 10, bottom: 40 },
            xAxis: { type: 'category', data: days.map(d => d.slice(5)), axisTick: { show: false }, axisLine: { lineStyle: { color: t.axis } }, axisLabel: { color: t.text, fontSize: 11 } },
            yAxis: { type: 'category', data: Array.from({length:24}, (_,i) => String(i).padStart(2,'0')), axisTick: { show: false }, axisLine: { lineStyle: { color: t.axis } }, axisLabel: { color: t.text, fontSize: 11 } },
            visualMap: { min: 0, max: maxVal || 1, show: false, inRange: { color: this.darkMode ? ['#111', '#0d3320', '#0a5c2f', '#0070f3', '#7c3aed'] : ['#f5f5f5', '#d1fae5', '#6ee7b7', '#0070f3', '#7c3aed'] } },
            series: [{ type: 'heatmap', data: hmData, itemStyle: { borderRadius: 2 }, emphasis: { itemStyle: { borderColor: '#fff', borderWidth: 1 } } }],
          });
        }

        // Daily trend
        const dc = this.getChart('dailyChart');
        if (dc) {
          const daily = this.data.daily || [];
          dc.setOption({
            tooltip: { trigger: 'axis', backgroundColor: t.tooltip, borderColor: t.tooltipBorder, textStyle: { color: this.darkMode ? '#eee' : '#333', fontSize: 12 } },
            legend: { data: ['Cost ($)', 'Sessions'], textStyle: { color: t.text, fontSize: 11 }, top: 0 },
            grid: { left: 50, right: 50, top: 36, bottom: 30 },
            xAxis: { type: 'category', data: daily.map(d => d.date.slice(5)), axisLine: { lineStyle: { color: t.axis } }, axisLabel: { color: t.text, fontSize: 11 } },
            yAxis: [
              { type: 'value', name: 'Cost ($)', nameTextStyle: { color: t.text, fontSize: 11 }, axisLabel: { color: t.text, fontSize: 11 }, splitLine: { lineStyle: { color: t.axis } } },
              { type: 'value', name: 'Sessions', nameTextStyle: { color: t.text, fontSize: 11 }, axisLabel: { color: t.text, fontSize: 11 }, splitLine: { show: false } },
            ],
            series: [
              { name: 'Cost ($)', type: 'line', data: daily.map(d => d.cost), smooth: true, symbol: 'none', lineStyle: { color: accent, width: 2 }, areaStyle: { color: new echarts.graphic.LinearGradient(0,0,0,1, [{offset:0,color:accent+'44'},{offset:1,color:accent+'05'}]) } },
              { name: 'Sessions', type: 'line', yAxisIndex: 1, data: daily.map(d => d.sessions), smooth: true, symbol: 'none', lineStyle: { color: success, width: 2 } },
            ],
          });
        }
      }

      if (this.tab === 'domains') {
        const ch = this.getChart('domainChart');
        if (ch) {
          const domains = this.data.domains || [];
          ch.setOption({
            tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' }, backgroundColor: t.tooltip, borderColor: t.tooltipBorder, textStyle: { color: this.darkMode ? '#eee' : '#333', fontSize: 12 } },
            grid: { left: 100, right: 30, top: 10, bottom: 20 },
            xAxis: { type: 'value', axisLabel: { color: t.text, fontSize: 11, formatter: '${value}' }, splitLine: { lineStyle: { color: t.axis } } },
            yAxis: { type: 'category', data: domains.map(d => d.name).reverse(), axisLabel: { color: t.text, fontSize: 12 }, axisTick: { show: false }, axisLine: { lineStyle: { color: t.axis } } },
            series: [{ type: 'bar', data: domains.map(d => d.cost).reverse(), itemStyle: { color: accent, borderRadius: [0, 4, 4, 0] }, barWidth: 20 }],
          });
        }
      }

      if (this.tab === 'tools') {
        // Commands
        const cc = this.getChart('cmdChart');
        if (cc) {
          const cmds = this.data.command_frequency || {};
          const sorted = Object.entries(cmds).sort((a,b) => b[1]-a[1]).slice(0, 15);
          cc.setOption({
            tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' }, backgroundColor: t.tooltip, borderColor: t.tooltipBorder, textStyle: { color: this.darkMode ? '#eee' : '#333', fontSize: 12 } },
            grid: { left: 100, right: 30, top: 10, bottom: 20 },
            xAxis: { type: 'value', axisLabel: { color: t.text, fontSize: 11 }, splitLine: { lineStyle: { color: t.axis } } },
            yAxis: { type: 'category', data: sorted.map(([k])=>k).reverse(), axisLabel: { color: t.text, fontSize: 11 }, axisTick: { show: false }, axisLine: { lineStyle: { color: t.axis } } },
            series: [{ type: 'bar', data: sorted.map(([,v])=>v).reverse(), itemStyle: { color: accent+'bb', borderRadius: [0,3,3,0] }, barWidth: 16 }],
          });
        }

        // Tool precision
        const tp = this.getChart('toolChart');
        if (tp) {
          const tools = this.data.tool_precision?.by_tool || {};
          const entries = Object.entries(tools).sort((a,b) => a[1]-b[1]);
          tp.setOption({
            tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' }, backgroundColor: t.tooltip, borderColor: t.tooltipBorder, textStyle: { color: this.darkMode ? '#eee' : '#333', fontSize: 12 }, formatter: p => `${p[0].name}: ${(p[0].value*100).toFixed(1)}%` },
            grid: { left: 80, right: 30, top: 10, bottom: 20 },
            xAxis: { type: 'value', min: 0, max: 1, axisLabel: { color: t.text, fontSize: 11, formatter: v=>(v*100)+'%' }, splitLine: { lineStyle: { color: t.axis } } },
            yAxis: { type: 'category', data: entries.map(([k])=>k), axisLabel: { color: t.text, fontSize: 11 }, axisTick: { show: false }, axisLine: { lineStyle: { color: t.axis } } },
            series: [{ type: 'bar', data: entries.map(([,v]) => ({ value: v, itemStyle: { color: v > 0.9 ? success : v > 0.8 ? warning : danger } })), barWidth: 16, itemStyle: { borderRadius: [0,3,3,0] } }],
          });
        }

        // Scatter
        const sc = this.getChart('scatterChart');
        if (sc) {
          const sessions = (this.data.costly_sessions || []);
          sc.setOption({
            tooltip: { formatter: p => `${p.data[2]}<br/>HIR: ${(p.data[0]*100).toFixed(1)}%<br/>Cost: $${p.data[1].toFixed(2)}`, backgroundColor: t.tooltip, borderColor: t.tooltipBorder, textStyle: { color: this.darkMode ? '#eee' : '#333', fontSize: 12 } },
            grid: { left: 60, right: 30, top: 20, bottom: 40 },
            xAxis: { name: 'HIR', nameLocation: 'center', nameGap: 25, nameTextStyle: { color: t.text, fontSize: 11 }, axisLabel: { color: t.text, fontSize: 11, formatter: v=>(v*100)+'%' }, splitLine: { lineStyle: { color: t.axis } } },
            yAxis: { name: 'Cost ($)', nameTextStyle: { color: t.text, fontSize: 11 }, axisLabel: { color: t.text, fontSize: 11, formatter: '${value}' }, splitLine: { lineStyle: { color: t.axis } } },
            series: [{ type: 'scatter', data: sessions.map(s => [s.hir, s.cost, s.project]), symbolSize: 10, itemStyle: { color: accent+'88' }, emphasis: { itemStyle: { color: accent, borderColor: '#fff', borderWidth: 1 } } }],
          });
        }
      }

      if (this.tab === 'context') {
        const cx = this.getChart('contextChart');
        if (cx) {
          const fills = this.data.context_fills || [];
          const colors = [accent, success, warning, danger, '#06b6d4', '#f97316', '#ec4899', '#8b5cf6', '#14b8a6', '#eab308'];
          const series = fills.map((f, i) => ({
            name: `${f.project} (${f.session_id.slice(0,6)})`,
            type: 'line',
            data: f.points.map(([idx, tok]) => [idx, tok]),
            smooth: true,
            symbol: 'none',
            lineStyle: { width: 1.5, color: colors[i % colors.length] },
          }));
          // Add marker lines
          const markLines = [
            { yAxis: 100000, name: '200K 50%', lineStyle: { color: warning+'55', type: 'dashed', width: 1 } },
            { yAxis: 160000, name: '200K 80%', lineStyle: { color: danger+'55', type: 'dashed', width: 1 } },
            { yAxis: 500000, name: '1M 50%', lineStyle: { color: warning+'33', type: 'dashed', width: 1 } },
            { yAxis: 800000, name: '1M 80%', lineStyle: { color: danger+'33', type: 'dashed', width: 1 } },
          ];
          if (series.length > 0) {
            series[0].markLine = { silent: true, symbol: 'none', label: { color: t.text, fontSize: 10, position: 'insideEndTop' }, data: markLines };
          }
          cx.setOption({
            tooltip: { trigger: 'axis', backgroundColor: t.tooltip, borderColor: t.tooltipBorder, textStyle: { color: this.darkMode ? '#eee' : '#333', fontSize: 11 } },
            legend: { type: 'scroll', textStyle: { color: t.text, fontSize: 10 }, top: 0 },
            grid: { left: 70, right: 30, top: 40, bottom: 30 },
            xAxis: { type: 'value', name: 'Message Index', nameLocation: 'center', nameGap: 25, nameTextStyle: { color: t.text, fontSize: 11 }, axisLabel: { color: t.text, fontSize: 11 }, splitLine: { lineStyle: { color: t.axis } } },
            yAxis: { type: 'value', name: 'Input Tokens', nameTextStyle: { color: t.text, fontSize: 11 }, axisLabel: { color: t.text, fontSize: 11, formatter: v => (v/1e6).toFixed(1)+'M' }, splitLine: { lineStyle: { color: t.axis } } },
            series,
          });
        }
      }

      // Resize handler
      window.onresize = () => { Object.values(this.charts).forEach(c => c?.resize()); };
    },
  }
}

// Init Lucide icons after DOM loads
document.addEventListener('DOMContentLoaded', () => { if (window.lucide) lucide.createIcons(); });
</script>
</body>
</html>
